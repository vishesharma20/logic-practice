#include <iostream>
using namespace std;

// Factorial using recursion
int factorial(int n)
{
    if (n <= 1)
        return 1;
    return n * factorial(n - 1);
}

// Fibonacci using recursion
int fibonacci(int n)
{
    if (n <= 1)
        return n;
    return fibonacci(n - 1) + fibonacci(n - 2);
}

// Sum of first N natural numbers
int sumOfN(int n)
{
    if (n == 0)
        return 0;
    return n + sumOfN(n - 1);
}

int main()
{
    int num;
    cout << "Enter a number: ";
    cin >> num;

    cout << "Factorial: " << factorial(num) << endl;
    cout << "Fibonacci: " << fibonacci(num) << endl;
    cout << "Sum of first N numbers: " << sumOfN(num) << endl;

    return 0;
}
