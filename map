#include <iostream>
#include <map>
#include <set>
using namespace std;

int main()
{
   
    map<string, int> studentMarks;

    studentMarks["Vishesh"] = 90;
    studentMarks["Rahul"] = 85;
    studentMarks["Aman"] = 92;

    cout << "Student Marks:\n";
    for (auto pair : studentMarks)
    {
        cout << pair.first << " -> " << pair.second << endl;
    }

    cout << "\n";

    set<int> numbers;

    numbers.insert(10);
    numbers.insert(20);
    numbers.insert(10);
    numbers.insert(30);

    cout << "Set elements:\n";
    for (int num : numbers)
    {
        cout << num << " ";
    }

    return 0;
}
