#include <iostream>
using namespace std;

int main()
{
    int num, original, reverse = 0, count = 0;

    cout << "Enter a number: ";
    cin >> num;

    original = num;

    while (num > 0)
    {
        int digit = num % 10;
        reverse = reverse * 10 + digit;
        num /= 10;
        count++;
    }

    cout << "Reversed number: " << reverse << endl;
    cout << "Number of digits: " << count << endl;

    return 0;
}
