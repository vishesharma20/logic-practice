#include <iostream>
using namespace std;

bool isPalindrome(int number)
{
    int original = number;
    int reverse = 0;

    while (number > 0)
    {
        int digit = number % 10;
        reverse = reverse * 10 + digit;
        number /= 10;
    }

    return original == reverse;
}

int main()
{
    int num;
    cout << "Enter a number: ";
    cin >> num;

    if (isPalindrome(num))
        cout << "Palindrome number";
    else
        cout << "Not a palindrome number";

    return 0;
}
